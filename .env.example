# ─────────────────────────────────────────────────────────────
# BusinessOS Pro — variables d'environnement
# Copiez ce fichier en `.env` et renseignez les valeurs.
# ─────────────────────────────────────────────────────────────

# Base de données PostgreSQL.
# En production (Vercel) : ajoutez l'intégration Neon depuis l'onglet Storage,
# elle définit automatiquement DATABASE_URL — rien à faire ici.
# En local : utilisez une URL Neon, ou un PostgreSQL local.
DATABASE_URL="postgresql://user:password@host:5432/businessos?sslmode=require"

# URL publique de l'app (liens email, invitations, réinitialisation).
# Optionnel sur Vercel : déduite automatiquement du domaine de déploiement.
# APP_URL="https://votre-domaine.vercel.app"

# Compte Super Administrateur créé au premier seed (optionnel — valeurs par défaut indiquées).
SUPERADMIN_EMAIL="admin@businessos.pro"
SUPERADMIN_PASSWORD="Admin1234!"

# Mode démo : les emails/SMS ne sont pas réellement envoyés.
# Les codes et liens sont consultables dans l'app sur /dev/inbox.
DEMO_MODE="true"
